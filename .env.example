# Copy this file to .env.local and fill in your values

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/pluto-mmc?retryWrites=true&w=majority

# NextAuth secret — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here

# Your deployed URL (or http://localhost:3000 for development)
NEXTAUTH_URL=http://localhost:3000

# Google OAuth — create at https://console.cloud.google.com
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Copy this file to .env.local and fill in your values

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/pluto-mmc?retryWrites=true&w=majority

# NextAuth secret — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here

# Your deployed URL (or http://localhost:3000 for development)
NEXTAUTH_URL=http://localhost:3000

# Google OAuth — create at https://console.cloud.google.com
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Anthropic Claude API — create at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# SSLCommerz — create at https://developer.sslcommerz.com
SSLCOMMERZ_STORE_ID=your-store-id
SSLCOMMERZ_STORE_PASSWORD=your-store-password

# Scraper Microservice — deploy scraper-service/ to Railway, then paste URL here
SCRAPER_SERVICE_URL=https://your-scraper.up.railway.app
SCRAPER_API_KEY=generate-a-random-secret-shared-between-nextjs-and-scraper
